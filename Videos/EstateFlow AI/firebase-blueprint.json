{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "agency_logo": { "type": "string" },
        "agency_name": { "type": "string" },
        "phone": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name"]
    },
    "Listing": {
      "title": "Listing",
      "description": "Real estate listing generated by AI",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string" },
        "input_data": { "type": "object" },
        "output_data": { "type": "object" },
        "view_count": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "input_data", "output_data"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Lead generated by the bot or landing page",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "listing_id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "property_interest": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Qualified", "Closed", "Lost"] },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Listing documents"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Lead documents"
    }
  }
}
